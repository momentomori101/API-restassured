{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id","name","data"],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["year","price","cpuModel","hardDiskSize"],
      "properties": {
        "year": {
          "type": "integer"
        },
        "price": {
          "type": "number"
        },
        "cpuModel": {
          "type": "string"
        },
        "hardDiskSize": {
          "type": "string"
        }
      }
    }
  }
}